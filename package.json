    "angularx-qrcode": "^21.0.5",
    "apexcharts": "^5.3.2",
    "browser-image-compression": "^2.0.2",
    "chart.js": "^4.4.9",
    "date-fns": "^4.1.0",
    "lucide-angular": "^1.0.0",
    "lz-string": "^1.5.0",
    "ng-apexcharts": "^2.0.4",
