    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.19",
    "@angular/cli": "~21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@types/jasmine": "~4.3.0",
    "@types/qrcode": "^1.5.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
